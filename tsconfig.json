{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "experimentalDecorators": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "importHelpers": true,
    "target": "ES2022",
    "useDefineForClassFields": false,
    "lib": [
      "es2022",
      "dom"
    ],
    "paths": {
      "tools": [
        "./dist/tools/tools", // <-- ADD THE LEADING ./ HERE
        "./dist/tools" // <-- ADD THE LEADING ./ HERE
      ]
    }
  },
  "angularCompilerOptions": {
    "strictTemplates": true,
    "strictInjectionParameters": true
  }
}
